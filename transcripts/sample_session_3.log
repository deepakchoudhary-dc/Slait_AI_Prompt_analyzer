import json
import logging

LOGGER = logging.getLogger(__name__)


def validate_json_file(path: str) -> bool:
    try:
        with open(path, "r", encoding="utf-8") as handle:
            json.load(handle)
        return True
    except (OSError, json.JSONDecodeError) as exc:
        LOGGER.error("Invalid json: %s", exc)
        return False
